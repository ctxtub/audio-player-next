# 服务端 HTTP 客户端的默认超时时间（毫秒）
HTTP_SERVER_TIMEOUT_MS=120_000

# OpenAI 文本生成（必填项）
OPENAI_API_KEY=sk-your-key
OPENAI_MODEL=gpt-4o-mini
# 可选：自定义 OpenAI Base URL（如走代理时需要），默认无需填写
# OPENAI_BASE_URL=https://api.openai.com/v1
# 可选：默认采样温度
# OPENAI_TEMPERATURE=0.7
# 可选：默认最大输出 token 数
# OPENAI_MAX_TOKENS=1024

# Azure Speech 服务（语音合成必填）
AZURE_SPEECH_KEY=your-azure-speech-key
AZURE_SPEECH_REGION=your-azure-region
# 语音白名单，需为 JSON 数组，value 需与 Azure 语音 ID 对应
AZURE_TTS_VOICE_ALLOW_LIST=[{"value":"en-US-JennyMultilingualNeural","label":"Jenny (EN)","description":"Default English voice"}]
# 默认语音 ID，必须出现在白名单 value 列表中
AZURE_TTS_DEFAULT_VOICE=en-US-JennyMultilingualNeural
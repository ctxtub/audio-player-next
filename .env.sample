# 数据库配置
# 本地开发使用相对路径，Docker 生产环境使用 /app/data/app.db
DATABASE_URL="file:./prisma/dev.db"

# 服务端 HTTP 客户端的默认超时时间（毫秒）
HTTP_SERVER_TIMEOUT_MS=120_000

# OpenAI 配置（必填项）
OPENAI_API_KEY=sk-your-key
# 故事生成专用模型
OPENAI_MODEL_STORY=gpt-4o
# Agent 流程专用模型
OPENAI_MODEL_AGENT=gpt-4o-mini
# 可选：自定义 OpenAI Base URL（如走代理时需要），默认无需填写
# OPENAI_BASE_URL=https://api.openai.com/v1
# 可选：默认采样温度
# OPENAI_TEMPERATURE=0.7
# 可选：默认最大输出 token 数
# OPENAI_MAX_TOKENS=1024

# OpenAI TTS 语音合成配置
# TTS 模型名称，支持 tts-1（快速）或 tts-1-hd（高质量），默认 tts-1
OPENAI_TTS_MODEL=tts-1
# 语音白名单，需为 JSON 数组，支持的语音：alloy, echo, fable, onyx, nova, shimmer
OPENAI_TTS_VOICE_LIST=[{"value":"alloy","label":"Alloy","description":"中性、平衡"},{"value":"nova","label":"Nova","description":"女性、活泼"},{"value":"shimmer","label":"Shimmer","description":"女性、温暖"}]
# 默认语音 ID，必须出现在白名单 value 列表中
OPENAI_TTS_DEFAULT_VOICE=alloy

# LangSmith Tracing 配置（可选）
# 开启 LangChain Tracing V2
LANGCHAIN_TRACING_V2=true
# LangSmith API Endpoint
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
# LangSmith API Key
LANGCHAIN_API_KEY=lsv2_...
# LangSmith 项目名称
LANGCHAIN_PROJECT=audio-player-next
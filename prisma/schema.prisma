// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                Int                 @id @default(autoincrement())
  username          String              @unique
  password          String
  nickname          String?
  createdAt         DateTime            @default(now())
  config            UserConfig?
  promptHistory     PromptHistory[]
  generationHistory GenerationHistory[]
  chatMessages      ChatMessage[]
}

/// 用户当前聊天会话的消息（单会话快照），与 User 多对一关联。
model ChatMessage {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// 会话内顺序
  position  Int
  /// 前端消息 id
  messageId String
  role      String
  content   String
  /// JSON 序列化的 parts（storyCard 的 audioUrl 已置空）
  parts     String?
  /// Agent 类型
  agentType String?
  /// 前端 createdAt ISO 字符串（展示用）
  createdAt String?

  @@index([userId, position])
}

/// 用户生成的故事历史，与 User 多对一关联。回放时据 storyText 重新合成音频。
model GenerationHistory {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// 触发生成的提示词
  prompt    String
  /// 生成的故事正文
  storyText String
  /// 生成时使用的音色（回放优先用它）
  voiceId   String   @default("")
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

/// 用户提示词使用历史，与 User 多对一关联。
model PromptHistory {
  id       Int      @id @default(autoincrement())
  userId   Int
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// 提示词原文
  prompt   String
  /// 最近一次使用时间
  lastUsed DateTime
  /// 累计使用次数
  useCount Int      @default(1)

  @@unique([userId, prompt])
}

/// 用户个性化配置，与 User 一对一关联。
model UserConfig {
  id                    Int      @id @default(autoincrement())
  userId                Int      @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// 允许播放时长，单位：分钟，范围 10-120
  playDurationMinutes   Int      @default(30)
  /// TTS 音色 ID，空字符串表示使用系统默认
  voiceId               String   @default("")
  /// 播放速率，范围 0.25-4.0，默认 1.0
  speed                 Float    @default(1.0)
  /// 是否启用浮动播放器
  floatingPlayerEnabled Boolean  @default(true)
  /// 主题模式：dark | light | system
  themeMode             String   @default("system")
  /// 预留扩展字段，存储 JSON 格式的未来配置项
  extras                String?
  updatedAt             DateTime @updatedAt
}
